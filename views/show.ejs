<% layout('/layouts/boilerplate') %>

<div class="show-container">
  <!-- Top Bar -->
  <div class="show-top-bar">
    <h1 class="show-title"><%= item.item %></h1>
    <% if(!isAdmin ){ %>
    <a href="/order/cart" class="show-cart-btn">
      <i class="fa-solid fa-cart-shopping"></i>
      <% if(crnUser && crnUser.order.length) { %>
      <span class="show-cart-count"><%= crnUser.order.length %></span>
      <% } %>
    </a>
    <% } %>
  </div>

  <!-- Main Content -->
  <div class="show-main">
    <!-- Image Section -->
    <div class="show-image-section">
      <img src="<%= item.image %>" alt="<%= item.item %>" class="show-image" />
    </div>

    <!-- Info Section -->
    <div class="show-info-section">
      <!-- Details -->
      <div class="show-details">
        <div class="show-detail-row">
          <span class="show-label">Restaurant:</span>
          <span class="show-value"><%= item.owner.shopName %></span>
        </div>
        
        <div class="show-detail-row">
          <span class="show-label">Price:</span>
          <span class="show-price">₹<%= item.price %></span>
        </div>

        <div class="show-detail-row">
          <span class="show-label">Description:</span>
          <p class="show-desc"><%= item.description %></p>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="show-buttons">
        <% if(crnUser && crnUser._id.equals(item.owner._id)){ %>
        <button onclick="location.href='/items/<%= item._id%>/edit'" class="show-btn show-btn-secondary">
          Edit
        </button>
        <form method="POST" action="/items/<%= item._id  %>?_method=DELETE" style="display: inline;">
          <button type="submit" class="show-btn show-btn-secondary">Delete</button>
        </form>
        <% } %>
        <a href="/order/<%= item._id %>" class="show-btn show-btn-primary">
          Add to Cart
        </a>
      </div>

      <!-- Reviews Section -->
      <div class="show-reviews">
        <h2 class="show-section-title">Reviews (<%= item.reviews ? item.reviews.length : 0 %>)</h2>
        
        <div class="show-reviews-list">
          <% if(item.reviews && item.reviews.length > 0) { %>
            <% for (review of item.reviews) { %>
            <div class="show-review-item">
              <div class="show-review-header">
                <strong><%= review.user.username %></strong>
                <p class="starability-result" data-rating="<%= review.rating %>"></p>
              </div>
              <p class="show-review-text"><%= review.comment %></p>
              <% if (crnUser && crnUser._id.equals(review.user._id)) { %>
              <form method="POST" action="/items/<%= item._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button type="submit" class="show-delete-review">Delete</button>
              </form>
              <% } %>
            </div>
            <% } %>
          <% } else { %>
          <p class="show-no-reviews">No reviews yet</p>
          <% } %>
        </div>

        <!-- Add Review Form -->
        <% if(crnUser && !isAdmin){ %>
        <div class="show-review-form">
          <h3 class="show-form-title">Add a Review</h3>
          <form method="POST" action="/items/<%= item._id %>/reviews" class="needs-validation" novalidate>
            <div class="show-form-group">
              <label class="show-form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>

            <div class="show-form-group">
              <label for="comment" class="show-form-label">Comment</label>
              <textarea name="review[comment]" id="comment" class="show-textarea" required></textarea>
            </div>

            <button type="submit" class="show-btn show-btn-primary">Submit</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script src="/js/cars.js"></script>
<script src="/js/formValidation.js"></script>
